,"u":"/docs/1.x/basics/request","h":"","p":1},{"i":5,"t":"The request object provides access to the request body and query parameters. export class UserController { @Route({method: 'POST', path: '/users'}) store({request}: IScope) { const {body, query} = request; } }","s":"Request body and query parameters","u":"/docs/1.x/basics/request","h":"#request-body-and-query-parameters","p":1},{"i":7,"t":"If you need to allow file uploads on a specific route, pass multipart: true in the route options. export class UserController { @Route({method: 'POST', path: '/users', options: {multipart: true}}) store(scope: IScope) { const avatar = scope.request.files?.avatar as unknown as IUploadedFile; } }","s":"File uploads","u":"/docs/1.x/basics/request","h":"#file-uploads","p":1},{"i":10,"t":"The request object contains information about the incoming request, such as path, host, and method. export class UserController { @Route({method: 'POST', path: '/users'}) store({request}: IScope) { const {path, host, method} = request; } }","s":"Request properties","u":"/docs/1.x/basics/request","h":"#request-properties","p":1},{"i":12,"t":"You can access request parameters using the params property. export class UserController { @Route({method: 'GET', path: '/users/:id'}) show({request}: IScope) { const {params} = request; const userId = params.id; } }","s":"Request parameters","u":"/docs/1.x/basics/request","h":"#request-parameters","p":1},{"i":14,"t":"You can access request headers using the headers property. export class UserController { @Route({method: 'POST', path: '/users'}) store({request}: IScope) { const {headers} = request; const contentType = headers['content-type']; } }","s":"Request headers","u":"/docs/1.x/basics/request","h":"#request-headers","p":1},{"i":16,"t":"All controller methods should return a response. You can set response data using the response object of IScope.","s":"Http Response","u":"/docs/1.x/basics/response","h":"","p":15},{"i":18,"t":"The response body can be string, Buffer, Stream, Object, Array, null, or undefined. export class UserController { @Route({method: 'GET', path: '/users/:id'}) show({response, params}: IScope) { const user = findUserById(params.id); response.body = user; } }","s":"Response Body","u":"/docs/1.x/basics/response","h":"#response-body","p":15},{"i":20,"t":"By default, the response status is 404. You can set the response status using the status property of response. export class UserController { @Route({method: 'GET', path: '/users/:id'}) show({response, params}: IScope) { const user = findUserById(params.id); if (!user) { response.status = 404; response.body = {message: 'User not found'}; return; } response.body = user; } } Since response.status defaults to 404, sending a response without a body and with a different status is done like this: scope.response.status = 204; If response.status has not been set, the status will be set to 200 or 204 depending on response.body. Specifically, if response.body has been set as null or undefined, the status will be set to 204. Otherwise, it will be set to 200.","s":"Response Status","u":"/docs/1.x/basics/response","h":"#response-status","p":15},{"i":22,"t":"There are two ways to set response headers: scope.response .setHeader('X-Header-One', 'Header Value') .setHeader('X-Header-Two', 'Header Value'); scope.response.withHeaders({ 'X-Header-One': 'Header Value', 'X-Header-Two': 'Header Value', }); As you have seen, both helpers are chainable.","s":"Response Headers","u":"/docs/1.x/basics/response","h":"#response-headers","p":15},{"i":24,"t":"When your application receives a request, it calls a controller method to generate the response. The routing configuration defines which action to run for each incoming URL.","s":"Routing","u":"/docs/1.x/basics/routing","h":"","p":23},{"i":26,"t":"Routes can be defined by adding the @Route decorator to a controller method. Due to the way decorators work in TypeScript, you must also add the controller class to the controllers array in config/app.ts. // src/controller/HomeController.ts import {type IScope, Route} from '@koala-ts/framework'; export class HomeController { @Route({method: 'GET', path: '/'}) index(scope: IScope): void { scope.response.body = {ok: true}; } } // src/config/app.ts import {type IKoalaConfig} from '@koala-ts/framework'; import {HomeController} from '../controller/HomeController'; export const appConfig: IKoalaConfig = { controllers: [HomeController], }; In the example above, the index method of HomeController will be called when the application receives a GET request to /.","s":"Defining Routes","u":"/docs/1.x/basics/routing","h":"#defining-routes","p":23},{"i":28,"t":"The method property of the @Route decorator can be used to match specific HTTP methods. The value can be one of the following methods: GET, POST, PUT, PATCH, DELETE, OPTIONS, or HEAD. You can also match multiple HTTP methods by passing an array of methods to the method property. @Route({method: 'GET', path: '/'}) @Route({method: ['GET', 'POST'], path: '/'}) And to match all HTTP methods, you can use the ALL or ANY method. @Route({method: 'ALL', path: '/'}) @Route({method: 'ANY', path: '/'})","s":"Matching HTTP Methods","u":"/docs/1.x/basics/routing","h":"#matching-http-methods","p":23},{"i":30,"t":"You can define route parameters by adding a colon : followed by the parameter name in the path property of the @Route decorator. @Route({method: 'GET', path: '/user/:id'}) Then you can access the parameter value in the controller method by using scope.params. const {id} = scope.params;","s":"Route Parameters","u":"/docs/1.x/basics/routing","h":"#route-parameters","p":23},{"i":32,"t":"You can add multiple middleware functions to a route by passing an array of middleware functions to the middleware property of the @Route decorator. // src/controller/HomeController.ts export class HomeController { @Route({method: 'GET', path: '/', middleware: [exampleMiddleware]}) index(scope: IScope): void { scope.response.body = {ok: true}; } } Below is an example of a middleware function. // src/middleware/exampleMiddleware.ts export async function exampleMiddleware( scope: IScope, next: INext, ): Promise<void> { console.log('Example middleware: Before controller'); await next(); console.log('Example middleware: After controller'); }","s":"Middleware","u":"/docs/1.x/basics/routing","h":"#middleware","p":23},{"i":34,"t":"Applications often need to be configured to run in different environments. For example, you might want to use a different database in development than in production. Thanks to dotenv, KoalaTs provides a practical way to manage application configuration.","s":"Configuration","u":"/docs/1.x/get-started/configuration","h":"","p":33},{"i":36,"t":"A fresh KoalaTs application contains a .env file in the root of your project. This file contains the default values needed to run your application. It also comes with a .env.test file that contains the default values for your tests.","s":"Environment files","u":"/docs/1.x/get-started/configuration","h":"#environment-files","p":33},{"i":38,"t":"You can access configuration values using the process.env object. For example, to access the PORT value, you can use the following code: const port = process.env.PORT;","s":"Accessing configuration values","u":"/docs/1.x/get-started/configuration","h":"#accessing-configuration-values","p":33},{"i":40,"t":"If you need to override an environment value, you can do that in a .env.local file: DATABASE_URL=\"mysql://root:@127.0.0.1:3306/my_database_name\" caution The .env.local file should not be committed to your repository. It is meant to be used for local development only. Several other .env files are available to set environment variables in the right situation: .env: defines the default values of the env vars needed by the application .env.local: overrides the default values for all environments but only on the machine which contains the file .env.<environment> such as .env.test: overrides env vars only for one environment but for all machines .env.<environment>.local such as .env.test.local: defines machine-specific env var overrides only for one environment","s":"Overriding configuration values","u":"/docs/1.x/get-started/configuration","h":"#overriding-configuration-values","p":33},{"i":42,"t":"The environment is selected by the NODE_ENV environment variable. If you do not set it, the default value is development. You can set it before running your application: NODE_ENV=production npm start Or in your package.json scripts: { \"scripts\": { \"start\": \"NODE_ENV=production node dist/index.js\" } }","s":"Selecting the environment","u":"/docs/1.x/get-started/configuration","h":"#selecting-the-environment","p":33},{"i":44,"t":"Welcome to KoalaTs. KoalaTs is crafted for backend developers who want a clear starting point for controllers, routing, request handling, response handling, and configuration.","s":"KoalaTs","u":"/docs/1.x/overview/intro","h":"","p":43},{"i":46,"t":"To get started, you can use the KoalaTs CLI to generate a new project: npx @koala-ts/cli create my-app The command generates a new project in the my-app directory. Then navigate to the project directory and start the server: cd my-app npm install npm run start","s":"Getting Started","u":"/docs/1.x/overview/intro","h":"#getting-started","p":43},{"i":48,"t":"Learn how to configure your application in Configuration. Define your first endpoints in Routing. Read how request data is exposed in Request. Control response output in Response.","s":"Next Steps","u":"/docs/1.x/overview/intro","h":"#next-steps","p":43}],"index":{"version":"2.3.9","fields":["t"],"fieldVectors":[["t/2",[0,1.023,1,3.856,2,2.328,3,1.443,4,1.618,5,2.677,6,1.817,7,2.677,8,1.289,9,2.677]],["t/5",[0,0.796,5,2.083,6,1.413,8,1.517,10,1.594,11,2.793,12,4.022,13,2.083,14,1.003,15,1.003,16,1.259,17,0.919,18,0.796,19,1.594,20,0.796,21,1.413,22,2.083,23,0.894]],["t/7",[0,0.726,2,1.651,14,0.914,15,0.914,16,1.147,17,0.89,18,0.726,